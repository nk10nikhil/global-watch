---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Global Watch Blog",
  "description": "Analysis, guides, and deep dives on real-time intelligence, OSINT, geopolitics, markets, and the open-source tools behind Global Watch.",
  "url": "https://globalwatch.vercel.app/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "Global Watch",
    "url": "https://globalwatch.vercel.app",
    "logo": {
      "@type": "ImageObject",
      "url": "https://globalwatch.vercel.app/favico/apple-touch-icon.png"
    }
  },
  "blogPost": posts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "url": `https://globalwatch.vercel.app/blog/posts/${post.id}/`,
    "image": post.data.heroImage ? `https://globalwatch.vercel.app${post.data.heroImage}` : "https://globalwatch.vercel.app/favico/og-image.png"
  }))
};
---

<Base
  title="Global Watch Blog"
  description="Insights on real-time global intelligence, OSINT, geopolitics, markets, and the open-source tools that power situational awareness."
  metaTitle="Global Watch Blog | Real-Time Intelligence, OSINT, Geopolitics & Markets"
  jsonLd={jsonLd}
>
  <div class="blog-hero">
    <div class="badge">
      <span class="dot"></span>
      Intelligence Feed
    </div>
    <h1>Noise<span class="green">.</span>Signal<span class="green">.</span>Blog</h1>
    <p class="subtitle">
      Analysis, guides, and deep dives on real-time intelligence, OSINT, geopolitics, markets, and the open-source tools behind Global Watch.
    </p>
  </div>
  <div class="blog-list">
    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/blog/posts/${post.id}/`} class="post-card">
          {post.data.heroImage && (
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="post-card-img"
              loading="lazy"
              width="600"
              height="315"
            />
          )}
          <div class="tag">{post.data.audience}</div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
